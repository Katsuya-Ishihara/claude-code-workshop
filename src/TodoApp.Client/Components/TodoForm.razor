@using TodoApp.Shared.Models
@using TodoApp.Shared.Requests

<EditForm Model="@_model" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label for="title" class="form-label">タイトル</label>
        <InputText id="title" class="form-control" @bind-Value="_model.Title" />
        <ValidationMessage For="@(() => _model.Title)" />
    </div>

    <div class="mb-3">
        <label for="description" class="form-label">説明</label>
        <InputTextArea id="description" class="form-control" rows="4" @bind-Value="_model.Description" />
    </div>

    <div class="mb-3">
        <label for="priority" class="form-label">優先度</label>
        <InputSelect id="priority" class="form-select" @bind-Value="_model.Priority">
            <option value="">未選択</option>
            <option value="@Priority.Low">Low</option>
            <option value="@Priority.Medium">Medium</option>
            <option value="@Priority.High">High</option>
        </InputSelect>
    </div>

    <div class="mb-3">
        <label for="dueDate" class="form-label">期限</label>
        <InputDate id="dueDate" class="form-control" @bind-Value="_model.DueDate" />
    </div>

    <div class="mb-3">
        <UserSelect @bind-SelectedUserId="_model.AssignedToUserId" Label="担当者" />
    </div>

    <button type="submit" class="btn btn-primary">@SubmitButtonText</button>
</EditForm>

@code {
    private CreateTodoRequest _model = new() { Title = string.Empty };

    [Parameter]
    public CreateTodoRequest? InitialValue { get; set; }

    [Parameter]
    public EventCallback<CreateTodoRequest> OnSubmit { get; set; }

    [Parameter]
    public string SubmitButtonText { get; set; } = "作成";

    protected override void OnParametersSet()
    {
        if (InitialValue is not null)
        {
            _model = new CreateTodoRequest
            {
                Title = InitialValue.Title,
                Description = InitialValue.Description,
                Priority = InitialValue.Priority,
                DueDate = InitialValue.DueDate,
                AssignedToUserId = InitialValue.AssignedToUserId
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        await OnSubmit.InvokeAsync(_model);
    }
}
