@page "/todos"
@attribute [Authorize]
@inject ITodoApiClient TodoApiClient
@inject IUserApiClient UserApiClient
@inject NavigationManager NavigationManager

<h3>Todo 一覧</h3>

<div class="d-flex justify-content-between align-items-center mb-3">
    <SearchBar Placeholder="Todoを検索..." OnSearch="HandleSearch" />
    <button class="btn btn-primary btn-create" @onclick="NavigateToCreate">新規作成</button>
</div>

@if (_isLoading)
{
    <div class="text-center my-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">読み込み中...</span>
        </div>
        <p>読み込み中...</p>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">
        @_errorMessage
    </div>
}
else if (!_todos.Any())
{
    <div class="text-center my-5">
        <p>Todoがありません</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var todo in PagedTodos)
        {
            <div class="col">
                <TodoCard Todo="@todo"
                          AssigneeName="@GetAssigneeName(todo.AssignedToUserId)"
                          OnClick="@NavigateToDetail" />
            </div>
        }
    </div>

    <div class="mt-3 d-flex justify-content-center">
        <Pagination CurrentPage="_currentPage"
                    TotalPages="_totalPages"
                    OnPageChanged="HandlePageChanged" />
    </div>
}

@code {
    private List<TodoResponse> _todos = new();
    private List<UserResponse> _users = new();
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _searchText = string.Empty;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private const int PageSize = 10;

    private List<TodoResponse> PagedTodos => _todos;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;

            var todosTask = TodoApiClient.GetAllPagedAsync(_currentPage, PageSize, string.IsNullOrWhiteSpace(_searchText) ? null : _searchText);
            var usersTask = UserApiClient.GetUsersAsync();
            await Task.WhenAll(todosTask, usersTask);

            var pagedResult = await todosTask;
            _todos = pagedResult.Items;
            _totalPages = pagedResult.TotalPages;
            _users = await usersTask;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"データの読み込みに失敗しました: {ex.Message}");
            _errorMessage = "データの読み込みに失敗しました";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string? GetAssigneeName(int? userId)
    {
        if (userId is null) return null;
        return _users.FirstOrDefault(u => u.Id == userId)?.DisplayName;
    }

    private async Task HandleSearch(string searchText)
    {
        _searchText = searchText;
        _currentPage = 1;
        await LoadDataAsync();
    }

    private async Task HandlePageChanged(int page)
    {
        _currentPage = page;
        await LoadDataAsync();
    }

    private void NavigateToDetail(int todoId)
    {
        NavigationManager.NavigateTo($"/todos/{todoId}");
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/todos/create");
    }
}
